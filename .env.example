# Astro DB Studio (Producción)
# Obtener en: https://studio.astro.build/
ASTRO_STUDIO_APP_TOKEN=your_token_here

# JWT Secret (genera uno aleatorio seguro)
# Puedes usar: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_random_secret_key_here

# URL del sitio (cambiar en producción)
SITE_URL=http://localhost:4321

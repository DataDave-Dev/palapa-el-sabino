---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Button from '../components/ui/Button.astro';
import { Check, Star, Home, Building, Calendar, Users, MapPin } from '@lucide/astro';
---

<Layout title="Precios - Quinta El Cielo">
  <Navigation />

  <div class="pt-24 pb-20 bg-stone-50 min-h-screen">
    <div class="max-w-7xl mx-auto px-6">
      <!-- Header -->
      <div class="text-center mb-16 animate-fade-in">
        <h1 class="text-5xl md:text-6xl lg:text-7xl font-light tracking-tight text-stone-800 mb-6">
          Precios
        </h1>
        <div class="h-px w-24 bg-stone-300 mx-auto mb-8"></div>
        <p class="text-xl text-stone-600 font-light max-w-2xl mx-auto leading-relaxed">
          Experimenta la tranquilidad de la sierra con opciones diseñadas para grupos de todos los tamaños
        </p>
      </div>

      <!-- Pricing Cards -->
      <div class="grid lg:grid-cols-2 gap-8 max-w-6xl mx-auto mb-20">
        <!-- Planta Baja -->
        <div class="bg-white rounded-2xl shadow-lg border border-stone-200 overflow-hidden hover:shadow-xl transition-all duration-300 hover:-translate-y-1 animate-fade-in-up" style="animation-delay: 0.1s;">
          <div class="bg-gradient-to-br from-stone-700 to-stone-800 p-8 lg:p-10 text-white relative overflow-hidden">
            <div class="absolute top-0 right-0 w-64 h-64 bg-white/5 rounded-full -translate-y-32 translate-x-32"></div>
            <div class="relative">
              <div class="flex items-start justify-between mb-6">
                <div class="flex items-center gap-3">
                  <div class="p-3 bg-white/10 rounded-lg backdrop-blur-sm">
                    <Home class="w-7 h-7" />
                  </div>
                  <div>
                    <h3 class="text-3xl font-light tracking-tight">Planta Baja</h3>
                    <p class="text-stone-200 font-light">Habitación Paraíso</p>
                  </div>
                </div>
              </div>
              <div class="mb-6">
                <div class="flex items-baseline gap-2">
                  <span class="text-6xl font-light tracking-tight">$5,499</span>
                </div>
                <p class="text-stone-200 font-light mt-2">Fin de semana completo</p>
                <p class="text-stone-300 text-sm font-light mt-1">Viernes a Domingo</p>
              </div>
            </div>
          </div>

          <div class="p-8 lg:p-10">
            <h4 class="text-lg font-medium text-stone-800 mb-6">¿Qué incluye?</h4>
            <ul class="space-y-4 mb-8">
              <li class="flex items-start gap-3 group">
                <div class="p-1 rounded-full bg-emerald-50 group-hover:bg-emerald-100 transition-colors">
                  <Check class="w-5 h-5 text-emerald-600 flex-shrink-0" />
                </div>
                <span class="text-stone-700 font-light leading-relaxed">Acceso completo a planta baja</span>
              </li>
              <li class="flex items-start gap-3 group">
                <div class="p-1 rounded-full bg-emerald-50 group-hover:bg-emerald-100 transition-colors">
                  <Check class="w-5 h-5 text-emerald-600 flex-shrink-0" />
                </div>
                <span class="text-stone-700 font-light leading-relaxed">Habitación Paraíso con camas cómodas</span>
              </li>
              <li class="flex items-start gap-3 group">
                <div class="p-1 rounded-full bg-emerald-50 group-hover:bg-emerald-100 transition-colors">
                  <Check class="w-5 h-5 text-emerald-600 flex-shrink-0" />
                </div>
                <span class="text-stone-700 font-light leading-relaxed">Cocina equipada completa</span>
              </li>
              <li class="flex items-start gap-3 group">
                <div class="p-1 rounded-full bg-emerald-50 group-hover:bg-emerald-100 transition-colors">
                  <Check class="w-5 h-5 text-emerald-600 flex-shrink-0" />
                </div>
                <span class="text-stone-700 font-light leading-relaxed">Asador y disco para cocinar al aire libre</span>
              </li>
              <li class="flex items-start gap-3 group">
                <div class="p-1 rounded-full bg-emerald-50 group-hover:bg-emerald-100 transition-colors">
                  <Check class="w-5 h-5 text-emerald-600 flex-shrink-0" />
                </div>
                <span class="text-stone-700 font-light leading-relaxed">Medio baño</span>
              </li>
            </ul>

            <a href="/reservar" class="block">
              <Button variant="outline" size="lg" fullWidth>
                Reservar Planta Baja
              </Button>
            </a>
          </div>
        </div>

        <!-- Cabaña Completa -->
        <div class="bg-white rounded-2xl shadow-xl border-2 border-stone-800 overflow-hidden relative hover:shadow-2xl transition-all duration-300 hover:-translate-y-1 animate-fade-in-up" style="animation-delay: 0.2s;">
          <!-- Popular Badge -->
          <div class="absolute top-6 right-6 bg-gradient-to-r from-stone-800 to-stone-900 text-white px-5 py-2.5 rounded-full flex items-center gap-2 font-medium text-sm shadow-lg z-10">
            <Star class="w-4 h-4 fill-current" />
            Más Popular
          </div>

          <div class="bg-gradient-to-br from-stone-800 via-stone-900 to-stone-950 p-8 lg:p-10 text-white relative overflow-hidden">
            <div class="absolute top-0 right-0 w-96 h-96 bg-white/5 rounded-full -translate-y-48 translate-x-48"></div>
            <div class="absolute bottom-0 left-0 w-64 h-64 bg-white/5 rounded-full translate-y-32 -translate-x-32"></div>
            <div class="relative">
              <div class="flex items-start justify-between mb-6">
                <div class="flex items-center gap-3">
                  <div class="p-3 bg-white/10 rounded-lg backdrop-blur-sm">
                    <Building class="w-7 h-7" />
                  </div>
                  <div>
                    <h3 class="text-3xl font-light tracking-tight">Cabaña Completa</h3>
                    <p class="text-stone-200 font-light">4 Habitaciones · 15-20 personas</p>
                  </div>
                </div>
              </div>
              <div class="mb-6">
                <div class="flex items-baseline gap-2">
                  <span class="text-6xl font-light tracking-tight">$8,500</span>
                </div>
                <p class="text-stone-200 font-light mt-2">Fin de semana completo</p>
                <p class="text-stone-300 text-sm font-light mt-1">Viernes a Domingo</p>
              </div>
            </div>
          </div>

          <div class="p-8 lg:p-10">
            <h4 class="text-lg font-medium text-stone-800 mb-6">¿Qué incluye?</h4>
            <ul class="space-y-4 mb-8">
              <li class="flex items-start gap-3 group">
                <div class="p-1 rounded-full bg-emerald-50 group-hover:bg-emerald-100 transition-colors">
                  <Check class="w-5 h-5 text-emerald-600 flex-shrink-0" />
                </div>
                <span class="text-stone-800 font-medium leading-relaxed">Todo lo de Planta Baja +</span>
              </li>
              <li class="flex items-start gap-3 group">
                <div class="p-1 rounded-full bg-emerald-50 group-hover:bg-emerald-100 transition-colors">
                  <Check class="w-5 h-5 text-emerald-600 flex-shrink-0" />
                </div>
                <span class="text-stone-700 font-light leading-relaxed">3 Habitaciones adicionales (Edén, Cielo y Nubes)</span>
              </li>
              <li class="flex items-start gap-3 group">
                <div class="p-1 rounded-full bg-emerald-50 group-hover:bg-emerald-100 transition-colors">
                  <Check class="w-5 h-5 text-emerald-600 flex-shrink-0" />
                </div>
                <span class="text-stone-700 font-light leading-relaxed">3 baños completos con agua caliente</span>
              </li>
              <li class="flex items-start gap-3 group">
                <div class="p-1 rounded-full bg-emerald-50 group-hover:bg-emerald-100 transition-colors">
                  <Check class="w-5 h-5 text-emerald-600 flex-shrink-0" />
                </div>
                <span class="text-stone-700 font-light leading-relaxed">Vistas panorámicas desde cada habitación</span>
              </li>
              <li class="flex items-start gap-3 group">
                <div class="p-1 rounded-full bg-emerald-50 group-hover:bg-emerald-100 transition-colors">
                  <Check class="w-5 h-5 text-emerald-600 flex-shrink-0" />
                </div>
                <span class="text-stone-700 font-light leading-relaxed">Espacios amplios para grupos grandes</span>
              </li>
            </ul>

            <a href="/reservar" class="block">
              <Button variant="primary" size="lg" fullWidth>
                Reservar Cabaña Completa
              </Button>
            </a>
          </div>
        </div>
      </div>

      <!-- Features Grid -->
      <div class="max-w-6xl mx-auto mb-20 animate-fade-in-up" style="animation-delay: 0.3s;">
        <h2 class="text-3xl md:text-4xl font-light tracking-tight text-stone-800 text-center mb-12">
          Incluido en todas las reservas
        </h2>
        <div class="grid md:grid-cols-3 gap-6">
          <div class="bg-white rounded-xl p-8 border border-stone-200 hover:shadow-lg transition-shadow">
            <div class="w-12 h-12 rounded-lg bg-stone-100 flex items-center justify-center mb-4">
              <Calendar class="w-6 h-6 text-stone-700" />
            </div>
            <h3 class="text-lg font-medium text-stone-800 mb-2">Fines de Semana</h3>
            <p class="text-stone-600 font-light leading-relaxed">
              Entrada viernes por la tarde, salida domingo. Disfruta 3 días completos en la sierra.
            </p>
          </div>

          <div class="bg-white rounded-xl p-8 border border-stone-200 hover:shadow-lg transition-shadow">
            <div class="w-12 h-12 rounded-lg bg-stone-100 flex items-center justify-center mb-4">
              <MapPin class="w-6 h-6 text-stone-700" />
            </div>
            <h3 class="text-lg font-medium text-stone-800 mb-2">Ubicación Privilegiada</h3>
            <p class="text-stone-600 font-light leading-relaxed">
              A 80 minutos de Monterrey a 3,550m de altitud con acceso vehicular de concreto.
            </p>
          </div>

          <div class="bg-white rounded-xl p-8 border border-stone-200 hover:shadow-lg transition-shadow">
            <div class="w-12 h-12 rounded-lg bg-stone-100 flex items-center justify-center mb-4">
              <Users class="w-6 h-6 text-stone-700" />
            </div>
            <h3 class="text-lg font-medium text-stone-800 mb-2">Para Grupos</h3>
            <p class="text-stone-600 font-light leading-relaxed">
              Espacios amplios diseñados para reuniones familiares, retiros o escapadas con amigos.
            </p>
          </div>
        </div>
      </div>

      <!-- Additional Info -->
      <div class="max-w-4xl mx-auto animate-fade-in-up" style="animation-delay: 0.4s;">
        <div class="bg-gradient-to-br from-stone-800 to-stone-900 rounded-2xl p-8 md:p-12 shadow-xl text-white">
          <h3 class="text-2xl md:text-3xl font-light tracking-tight mb-8 text-center">
            Información Importante
          </h3>
          <div class="grid md:grid-cols-2 gap-6">
            <ul class="space-y-4">
              <li class="flex items-start gap-3">
                <Check class="w-5 h-5 text-emerald-400 flex-shrink-0 mt-0.5" />
                <span class="font-light">Precios por fin de semana completo</span>
              </li>
              <li class="flex items-start gap-3">
                <Check class="w-5 h-5 text-emerald-400 flex-shrink-0 mt-0.5" />
                <span class="font-light">Reservas requieren confirmación previa</span>
              </li>
              <li class="flex items-start gap-3">
                <Check class="w-5 h-5 text-emerald-400 flex-shrink-0 mt-0.5" />
                <span class="font-light">Solo disponible fines de semana</span>
              </li>
            </ul>
            <ul class="space-y-4">
              <li class="flex items-start gap-3">
                <Check class="w-5 h-5 text-emerald-400 flex-shrink-0 mt-0.5" />
                <span class="font-light">Asador y disco para cocinar incluidos</span>
              </li>
              <li class="flex items-start gap-3">
                <Check class="w-5 h-5 text-emerald-400 flex-shrink-0 mt-0.5" />
                <span class="font-light">Camino de concreto hasta la entrada</span>
              </li>
              <li class="flex items-start gap-3">
                <Check class="w-5 h-5 text-emerald-400 flex-shrink-0 mt-0.5" />
                <span class="font-light">Vistas espectaculares garantizadas</span>
              </li>
            </ul>
          </div>

          <div class="mt-10 text-center">
            <p class="text-stone-200 font-light mb-6">
              ¿Tienes preguntas? Contáctanos para más información
            </p>
            <a href="/reservar">
              <Button variant="outline" size="lg" class="bg-white/10 border-white/30 text-white hover:bg-white/20">
                Hacer una Reserva
              </Button>
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>

<style>
  @import "tailwindcss" reference;

  @keyframes fade-in {
    from {
      opacity: 0;
      transform: translateY(0);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes fade-in-up {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .animate-fade-in {
    animation: fade-in 0.6s ease-out;
  }

  .animate-fade-in-up {
    animation: fade-in-up 0.6s ease-out;
    animation-fill-mode: both;
  }
</style>

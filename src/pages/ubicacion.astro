---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import { MapPin, Navigation as NavigationIcon, Clock, Car, Mountain, AlertCircle } from '@lucide/astro';
---

<Layout title="Ubicación - Quinta El Cielo">
  <Navigation />

  <div class="pt-24 pb-20 bg-stone-50 min-h-screen">
    <div class="max-w-6xl mx-auto px-4">
      <!-- Header -->
      <div class="text-center mb-16">
        <h1 class="text-5xl md:text-6xl font-light tracking-tight text-stone-800 mb-4">
          Ubicación
        </h1>
        <p class="text-lg text-stone-600 font-light">
          Sierra de Arteaga, Coahuila
        </p>
      </div>

      <!-- Map Section -->
      <div class="bg-white rounded-2xl shadow-xl overflow-hidden mb-12">
        <div class="aspect-video bg-gradient-to-br from-emerald-400 to-sky-400 flex items-center justify-center">
          <div class="text-center text-white">
            <MapPin class="w-16 h-16 mx-auto mb-4" />
            <p class="text-lg font-medium">Mapa Interactivo</p>
            <p class="text-sm text-emerald-100 mt-2">
              Agrega aquí un iframe de Google Maps con la ubicación real
            </p>
          </div>
        </div>
      </div>

      <!-- Info Cards -->
      <div class="grid md:grid-cols-2 gap-8 mb-12">
        <!-- Direcciones -->
        <div class="bg-white rounded-xl p-8 shadow-lg border border-stone-200">
          <div class="flex items-center gap-3 mb-6">
            <div class="w-12 h-12 bg-stone-100 rounded-lg flex items-center justify-center">
              <NavigationIcon class="w-6 h-6 text-stone-700" />
            </div>
            <h3 class="text-2xl font-medium text-stone-800">Cómo Llegar</h3>
          </div>

          <div class="space-y-4 text-stone-600">
            <div>
              <h4 class="font-medium text-stone-800 mb-2">Desde Monterrey:</h4>
              <ol class="list-decimal list-inside space-y-2 text-sm font-light">
                <li>Tomar la carretera hacia Saltillo</li>
                <li>Continuar hacia Arteaga</li>
                <li>Seguir indicaciones a Sierra de Arteaga</li>
                <li>El camino de concreto te llevará directo a la cabaña</li>
              </ol>
            </div>

            <div class="pt-4 border-t border-stone-200">
              <div class="flex items-center gap-2 text-stone-700 font-medium">
                <Clock class="w-5 h-5" />
                <span>Tiempo aproximado: 80 minutos</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Detalles -->
        <div class="bg-white rounded-xl p-8 shadow-lg border border-stone-200">
          <div class="flex items-center gap-3 mb-6">
            <div class="w-12 h-12 bg-stone-100 rounded-lg flex items-center justify-center">
              <Mountain class="w-6 h-6 text-stone-700" />
            </div>
            <h3 class="text-2xl font-medium text-stone-800">Detalles</h3>
          </div>

          <div class="space-y-4">
            <div class="flex items-start gap-3">
              <MapPin class="w-5 h-5 text-stone-700 flex-shrink-0 mt-1" />
              <div>
                <p class="font-medium text-stone-800">Ubicación</p>
                <p class="text-stone-600 text-sm font-light">Sierra de Arteaga, Coahuila</p>
              </div>
            </div>

            <div class="flex items-start gap-3">
              <Mountain class="w-5 h-5 text-stone-700 flex-shrink-0 mt-1" />
              <div>
                <p class="font-medium text-stone-800">Altitud</p>
                <p class="text-stone-600 text-sm font-light">3,550 metros sobre el nivel del mar</p>
              </div>
            </div>

            <div class="flex items-start gap-3">
              <Car class="w-5 h-5 text-stone-700 flex-shrink-0 mt-1" />
              <div>
                <p class="font-medium text-stone-800">Acceso Vehicular</p>
                <p class="text-stone-600 text-sm font-light">Camino de concreto hidráulico - Cualquier vehículo puede subir</p>
              </div>
            </div>

            <div class="flex items-start gap-3">
              <Clock class="w-5 h-5 text-stone-700 flex-shrink-0 mt-1" />
              <div>
                <p class="font-medium text-stone-800">Distancia desde Monterrey</p>
                <p class="text-stone-600 text-sm font-light">Aproximadamente 80 minutos</p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Recomendaciones -->
      <div class="bg-stone-100 border-2 border-stone-300 rounded-xl p-8">
        <div class="flex items-start gap-4">
          <AlertCircle class="w-8 h-8 text-stone-700 flex-shrink-0" />
          <div>
            <h3 class="text-xl font-medium text-stone-800 mb-3">Recomendaciones</h3>
            <ul class="space-y-2 text-stone-700 font-light">
              <li class="flex items-start gap-2">
                <span class="text-stone-600 mt-1">•</span>
                <span>Lleva ropa abrigadora, las temperaturas en la montaña pueden ser frías especialmente por la noche</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-stone-600 mt-1">•</span>
                <span>Carga gasolina antes de subir, no hay gasolineras cercanas en la sierra</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-stone-600 mt-1">•</span>
                <span>Verifica el clima antes de tu viaje, especialmente en temporada de lluvias</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-stone-600 mt-1">•</span>
                <span>Lleva tus provisiones desde Monterrey o Arteaga para mayor comodidad</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-stone-600 mt-1">•</span>
                <span>No olvides tu cámara para capturar las vistas espectaculares</span>
              </li>
            </ul>
          </div>
        </div>
      </div>

      <!-- CTA -->
      <div class="mt-12 text-center">
        <a
          href="/reservar"
          class="inline-block px-8 py-4 bg-stone-800 text-white rounded font-medium hover:bg-stone-900 transition-colors"
        >
          Reservar Ahora
        </a>
      </div>
    </div>
  </div>
</Layout>

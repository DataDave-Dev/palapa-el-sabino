---
import Layout from '../layouts/Layout.astro';
import Card from '../components/ui/Card.astro';
import Input from '../components/ui/Input.astro';
import Button from '../components/ui/Button.astro';
import { Mail, ArrowLeft, CheckCircle } from '@lucide/astro';

// Si ya está autenticado, redirigir
import { getUserFromCookies } from '../lib/auth';
const user = getUserFromCookies(Astro.cookies);
if (user) {
  return Astro.redirect('/');
}
---

<Layout title="Recuperar Contraseña - Cabaña Quinta El Cielo">
  <div class="min-h-screen bg-stone-50 flex items-center justify-center p-4">
    <div class="w-full max-w-md animate-fade-in">
      <!-- Logo -->
      <div class="text-center mb-8">
        <img
          src="/logo.png"
          alt="Cabaña Quinta El Cielo"
          class="h-20 md:h-24 w-auto mx-auto mb-6"
        />
        <h1 class="text-3xl font-light tracking-tight text-stone-800 mb-2">Recuperar Contraseña</h1>
        <p class="text-stone-600 font-light">Te enviaremos un enlace para restablecer tu contraseña</p>
      </div>

      <Card padding="lg">
        <!-- Form (shown initially) -->
        <form id="resetForm" class="space-y-5">
          <!-- Email Input -->
          <div>
            <Input
              type="email"
              name="email"
              id="email"
              label="Correo electrónico"
              placeholder="tu@email.com"
              required
              iconLeft={true}
              helperText="Ingresa el correo asociado a tu cuenta"
            >
              <Mail slot="icon-left" class="w-5 h-5" />
            </Input>
          </div>

          <!-- Error Message -->
          <div id="error-message" class="hidden"></div>

          <!-- Submit Button -->
          <Button type="submit" variant="primary" size="lg" fullWidth id="submit-button">
            Enviar Enlace de Recuperación
          </Button>

          <!-- Back to Login -->
          <div class="text-center">
            <a
              href="/login"
              class="inline-flex items-center gap-2 text-sm text-stone-700 hover:text-stone-900 font-medium transition-colors"
            >
              <ArrowLeft class="w-4 h-4" />
              Volver al inicio de sesión
            </a>
          </div>
        </form>

        <!-- Success Message (hidden initially) -->
        <div id="success-view" class="hidden space-y-5">
          <div class="text-center">
            <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-emerald-100 mb-4">
              <CheckCircle class="w-10 h-10 text-emerald-600" />
            </div>
            <h2 class="text-xl font-medium text-stone-800 mb-2">Correo Enviado</h2>
            <p class="text-stone-600 font-light mb-4">
              Hemos enviado un enlace de recuperación a
              <span id="sent-email" class="font-medium text-stone-800"></span>
            </p>
            <div class="bg-stone-100 border border-stone-200 rounded-lg p-4 text-sm text-stone-700 text-left space-y-2">
              <p class="font-medium">Revisa tu bandeja de entrada</p>
              <ul class="list-disc list-inside space-y-1 text-stone-600 font-light">
                <li>El enlace expirará en 1 hora</li>
                <li>Si no ves el correo, revisa tu carpeta de spam</li>
                <li>Puedes cerrar esta ventana</li>
              </ul>
            </div>
          </div>

          <Button
            type="button"
            variant="outline"
            size="lg"
            fullWidth
            onclick="window.location.href='/login'"
          >
            Volver al Inicio de Sesión
          </Button>
        </div>
      </Card>
    </div>
  </div>
</Layout>

<style>
  @import "tailwindcss" reference;

  @keyframes fade-in {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .animate-fade-in {
    animation: fade-in 0.4s ease-out;
  }
</style>

<script>
  const form = document.getElementById('resetForm') as HTMLFormElement;
  const errorDiv = document.getElementById('error-message');
  const submitButton = document.getElementById('submit-button') as HTMLButtonElement;
  const successView = document.getElementById('success-view');
  const sentEmailSpan = document.getElementById('sent-email');

  // Email validation
  const emailInput = document.getElementById('email') as HTMLInputElement;
  emailInput?.addEventListener('blur', () => {
    const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
    if (emailInput.value && !emailRegex.test(emailInput.value)) {
      emailInput.setCustomValidity('Por favor ingresa un correo válido');
    } else {
      emailInput.setCustomValidity('');
    }
  });

  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    // Clear previous errors
    if (errorDiv) {
      errorDiv.classList.add('hidden');
      errorDiv.innerHTML = '';
    }

    const email = emailInput.value;

    // Show loading state
    submitButton.setAttribute('loading', 'true');
    submitButton.disabled = true;
    submitButton.innerHTML = '<span class="absolute inset-0 flex items-center justify-center"><svg class="animate-spin h-5 w-5" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg></span><span class="opacity-0">Enviar Enlace de Recuperación</span>';

    try {
      const response = await fetch('/api/auth/reset-password', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify({ email })
      });

      const result = await response.json();

      if (!response.ok) {
        throw new Error(result.error || 'Error al enviar el enlace de recuperación');
      }

      // Success - show success view
      form.classList.add('hidden');
      if (successView && sentEmailSpan) {
        sentEmailSpan.textContent = email;
        successView.classList.remove('hidden');
      }
    } catch (error) {
      // Reset button
      submitButton.removeAttribute('loading');
      submitButton.disabled = false;
      submitButton.innerHTML = 'Enviar Enlace de Recuperación';

      // Show error
      if (errorDiv) {
        const errorMessage = error instanceof Error ? error.message : 'Error al enviar el enlace';
        errorDiv.innerHTML = `
          <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg flex items-start gap-3 animate-fade-in">
            <svg class="w-5 h-5 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
            </svg>
            <span class="flex-1">${errorMessage}</span>
          </div>
        `;
        errorDiv.classList.remove('hidden');
      }
    }
  });
</script>

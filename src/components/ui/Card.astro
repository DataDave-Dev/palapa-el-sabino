---
interface Props {
  class?: string;
  padding?: 'none' | 'sm' | 'md' | 'lg';
}

const {
  class: className = '',
  padding = 'md'
} = Astro.props;

const paddingClasses = {
  none: '',
  sm: 'p-4',
  md: 'p-6',
  lg: 'p-8'
};

const baseClasses = 'bg-white rounded-xl shadow-lg border border-slate-200';
---

<div class:list={[baseClasses, paddingClasses[padding], className]}>
  <slot />
</div>

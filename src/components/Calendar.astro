---
import { ChevronLeft, ChevronRight, Calendar as CalendarIcon } from '@lucide/astro';

interface Props {
  onDateSelect?: string;
}

const { onDateSelect } = Astro.props;
---

<div class="calendar-container bg-white rounded-xl shadow-lg p-6 border-2 border-stone-200">
  <!-- Calendar Header -->
  <div class="flex items-center justify-between mb-6">
    <h3 class="text-xl font-medium text-stone-800 flex items-center gap-2">
      <CalendarIcon class="w-6 h-6 text-stone-700" />
      <span id="calendar-month-year"></span>
    </h3>
    <div class="flex gap-2">
      <button
        id="prev-month"
        class="p-2 rounded-lg hover:bg-stone-100 text-stone-600 hover:text-stone-900 transition-colors"
        aria-label="Previous month"
      >
        <ChevronLeft class="w-5 h-5" />
      </button>
      <button
        id="next-month"
        class="p-2 rounded-lg hover:bg-stone-100 text-stone-600 hover:text-stone-900 transition-colors"
        aria-label="Next month"
      >
        <ChevronRight class="w-5 h-5" />
      </button>
    </div>
  </div>

  <!-- Calendar Grid -->
  <div class="calendar-grid">
    <!-- Day Headers -->
    <div class="grid grid-cols-7 gap-2 mb-2">
      <div class="text-center text-sm font-bold text-stone-800 py-2">Dom</div>
      <div class="text-center text-sm font-medium text-slate-400 py-2">Lun</div>
      <div class="text-center text-sm font-medium text-slate-400 py-2">Mar</div>
      <div class="text-center text-sm font-medium text-slate-400 py-2">Mié</div>
      <div class="text-center text-sm font-medium text-slate-400 py-2">Jue</div>
      <div class="text-center text-sm font-medium text-slate-400 py-2">Vie</div>
      <div class="text-center text-sm font-bold text-stone-800 py-2">Sáb</div>
    </div>

    <!-- Calendar Days -->
    <div id="calendar-days" class="grid grid-cols-7 gap-2"></div>
  </div>

  <!-- Legend -->
  <div class="mt-6 pt-6 border-t border-stone-200">
    <div class="mb-3 text-sm font-medium text-stone-700 bg-amber-50 border border-amber-200 rounded-lg px-3 py-2">
      Solo fines de semana disponibles (Sábado y Domingo)
    </div>
    <div class="flex flex-wrap gap-4 text-sm">
      <div class="flex items-center gap-2">
        <div class="w-4 h-4 rounded bg-stone-200 border border-stone-300"></div>
        <span class="text-stone-600 font-light">Disponible</span>
      </div>
      <div class="flex items-center gap-2">
        <div class="w-4 h-4 rounded bg-red-100 border border-red-300"></div>
        <span class="text-stone-600 font-light">Ocupado</span>
      </div>
      <div class="flex items-center gap-2">
        <div class="w-4 h-4 rounded bg-slate-100"></div>
        <span class="text-stone-600 font-light">No disponible</span>
      </div>
      <div class="flex items-center gap-2">
        <div class="w-4 h-4 rounded bg-stone-800"></div>
        <span class="text-stone-600 font-light">Seleccionado</span>
      </div>
    </div>
  </div>

  <!-- Selected Dates Display -->
  <div id="selected-dates-display" class="mt-6 hidden">
    <div class="bg-stone-100 border-2 border-stone-300 rounded-lg p-4">
      <p class="text-sm font-medium text-stone-800 mb-2">Fechas seleccionadas:</p>
      <div class="flex items-center gap-4 text-sm text-stone-700">
        <div>
          <span class="font-medium">Entrada:</span>
          <span id="start-date-display" class="ml-2"></span>
        </div>
        <div>
          <span class="font-medium">Salida:</span>
          <span id="end-date-display" class="ml-2"></span>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  @import "tailwindcss" reference;

  .calendar-day {
    aspect-ratio: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 0.5rem;
    font-weight: 500;
    transition: all 0.2s;
    cursor: pointer;
  }

  .calendar-day.available {
    @apply bg-stone-100 text-stone-700 hover:bg-stone-200 hover:border hover:border-stone-700;
  }

  .calendar-day.occupied {
    @apply bg-red-100 text-red-700 cursor-not-allowed;
  }

  .calendar-day.past {
    @apply bg-slate-100 text-slate-400 cursor-not-allowed;
  }

  .calendar-day.weekday {
    @apply bg-slate-100 text-slate-400 cursor-not-allowed;
  }

  .calendar-day.other-month {
    @apply text-slate-300;
  }

  .calendar-day.selected {
    @apply bg-stone-800 text-white border-2 border-stone-900;
  }

  .calendar-day.in-range {
    @apply bg-stone-300 text-stone-900;
  }
</style>

<script>
  let currentMonth = new Date().getMonth();
  let currentYear = new Date().getFullYear();
  let selectedStartDate: Date | null = null;
  let selectedEndDate: Date | null = null;
  let occupiedDates: string[] = [];

  // Fetch occupied dates
  async function fetchOccupiedDates() {
    try {
      const response = await fetch('/api/bookings/available');
      const data = await response.json();
      occupiedDates = data.occupiedDates || [];
      console.log('Fechas ocupadas cargadas:', occupiedDates.length, 'fechas');
    } catch (error) {
      console.error('Error fetching occupied dates:', error);
    }
  }

  function renderCalendar() {
    const monthYearEl = document.getElementById('calendar-month-year');
    const daysEl = document.getElementById('calendar-days');

    if (!monthYearEl || !daysEl) return;

    // Update month/year display
    const monthNames = [
      'Enero', 'Febrero', 'Marzo', 'Abril', 'Mayo', 'Junio',
      'Julio', 'Agosto', 'Septiembre', 'Octubre', 'Noviembre', 'Diciembre'
    ];
    monthYearEl.textContent = `${monthNames[currentMonth]} ${currentYear}`;

    // Clear previous days
    daysEl.innerHTML = '';

    // Get first day of month and number of days
    const firstDay = new Date(currentYear, currentMonth, 1).getDay();
    const daysInMonth = new Date(currentYear, currentMonth + 1, 0).getDate();
    const today = new Date();
    today.setHours(0, 0, 0, 0);

    // Add empty cells for days before first day of month
    for (let i = 0; i < firstDay; i++) {
      const emptyCell = document.createElement('div');
      daysEl.appendChild(emptyCell);
    }

    // Add day cells
    for (let day = 1; day <= daysInMonth; day++) {
      const date = new Date(currentYear, currentMonth, day);
      const dateStr = date.toISOString().split('T')[0];
      const dayCell = document.createElement('button');
      dayCell.textContent = day.toString();
      dayCell.className = 'calendar-day';
      dayCell.dataset.date = dateStr;

      // Get day of week (0 = Sunday, 6 = Saturday)
      const dayOfWeek = date.getDay();
      const isWeekend = dayOfWeek === 0 || dayOfWeek === 6;

      // Determine day status
      if (date < today) {
        dayCell.classList.add('past');
        dayCell.disabled = true;
      } else if (!isWeekend) {
        // Disable weekdays (Monday to Friday)
        dayCell.classList.add('weekday');
        dayCell.disabled = true;
      } else if (occupiedDates.includes(dateStr)) {
        dayCell.classList.add('occupied');
        dayCell.disabled = true;
      } else {
        dayCell.classList.add('available');

        // Check if selected
        if (selectedStartDate && date.getTime() === selectedStartDate.getTime()) {
          dayCell.classList.add('selected');
        } else if (selectedEndDate && date.getTime() === selectedEndDate.getTime()) {
          dayCell.classList.add('selected');
        } else if (selectedStartDate && selectedEndDate && date > selectedStartDate && date < selectedEndDate) {
          dayCell.classList.add('in-range');
        }

        dayCell.addEventListener('click', () => handleDateClick(date, dateStr));
      }

      daysEl.appendChild(dayCell);
    }
  }

  function handleDateClick(date: Date, dateStr: string) {
    if (!selectedStartDate || (selectedStartDate && selectedEndDate)) {
      // Start new selection
      selectedStartDate = date;
      selectedEndDate = null;
    } else if (date > selectedStartDate) {
      // Set end date
      selectedEndDate = date;
      updateSelectedDatesDisplay();
    } else {
      // Reset if clicked before start date
      selectedStartDate = date;
      selectedEndDate = null;
    }

    renderCalendar();
  }

  function updateSelectedDatesDisplay() {
    const displayEl = document.getElementById('selected-dates-display');
    const startDateEl = document.getElementById('start-date-display');
    const endDateEl = document.getElementById('end-date-display');

    if (!displayEl || !startDateEl || !endDateEl) return;

    if (selectedStartDate && selectedEndDate) {
      displayEl.classList.remove('hidden');
      startDateEl.textContent = selectedStartDate.toLocaleDateString('es-MX');
      endDateEl.textContent = selectedEndDate.toLocaleDateString('es-MX');

      // Dispatch custom event with selected dates
      const event = new CustomEvent('datesSelected', {
        detail: {
          startDate: selectedStartDate.toISOString().split('T')[0],
          endDate: selectedEndDate.toISOString().split('T')[0]
        }
      });
      document.dispatchEvent(event);
    } else {
      displayEl.classList.add('hidden');
    }
  }

  // Event listeners for month navigation
  document.getElementById('prev-month')?.addEventListener('click', () => {
    currentMonth--;
    if (currentMonth < 0) {
      currentMonth = 11;
      currentYear--;
    }
    renderCalendar();
  });

  document.getElementById('next-month')?.addEventListener('click', () => {
    currentMonth++;
    if (currentMonth > 11) {
      currentMonth = 0;
      currentYear++;
    }
    renderCalendar();
  });

  // Initialize
  fetchOccupiedDates().then(() => renderCalendar());
</script>
